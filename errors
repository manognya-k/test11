import time
import redis as redis_lib
import psycopg2
from pymongo import MongoClient
from fastapi import APIRouter, HTTPException
from pydantic import BaseModel
from backend.config import get_settings
from backend.ollama_client import invoke_llm_async

router = APIRouter(prefix="/health", tags=["health"])
settings = get_settings()


class ServiceStatus(BaseModel):
    status: str
    latency_ms: float | None = None
    error: str | None = None


class HealthResponse(BaseModel):
    overall: str
    services: dict[str, ServiceStatus]
    timestamp: float


def _check_postgres() -> ServiceStatus:
    t0 = time.perf_counter()
    try:
        conn = psycopg2.connect(settings.postgres_url, connect_timeout=3)

        conn.close()
        return ServiceStatus(status="ok", latency_ms=round((time.perf_counter() - t0) * 1000, 2))
    except Exception as e:
        return ServiceStatus(status="error", error=str(e))


def _check_redis() -> ServiceStatus:
    t0 = time.perf_counter()
    try:
        r = redis_lib.from_url(settings.redis_url, socket_connect_timeout=3)
        r.ping()
        return ServiceStatus(status="ok", latency_ms=round((time.perf_counter() - t0) * 1000, 2))
    except Exception as e:
        return ServiceStatus(status="error", error=str(e))


def _check_mongo() -> ServiceStatus:
    t0 = time.perf_counter()
    try:
        client = MongoClient(settings.mongo_url, serverSelectionTimeoutMS=3000)

        # MongoDB 7 fix: explicitly access a DB before ping
        db = client["admin"]
        db.command("ping")

        client.close()
        return ServiceStatus(
            status="ok",
            latency_ms=round((time.perf_counter() - t0) * 1000, 2),
        )
    except Exception as e:
        return ServiceStatus(status="error", error=str(e))


@router.get("/", response_model=HealthResponse)
def health_check():
    services = {
        "postgres": _check_postgres(),
        "redis": _check_redis(),
        "mongodb": _check_mongo(),
    }
    overall = "ok" if all(s.status == "ok" for s in services.values()) else "degraded"
    return HealthResponse(overall=overall, services=services, timestamp=time.time())


@router.get("/ollama", response_model=ServiceStatus)
async def ollama_health():
    t0 = time.perf_counter()
    try:
        response = await invoke_llm_async(
            system_prompt="You are a health check bot. Reply with exactly one word.",
            user_message="Respond with: OK",
            temperature=0.0,
        )
        return ServiceStatus(
            status="ok",
            latency_ms=round((time.perf_counter() - t0) * 1000, 2),
        )
    except Exception as e:
        raise HTTPException(status_code=503, detail=f"Ollama unreachable: {e}")

