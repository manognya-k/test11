"""
Standalone script to verify Ollama is reachable and responding correctly.
Run from the project root: python scripts/test_ollama.py
"""
import sys
import time

sys.path.insert(0, ".")

from backend.ollama_client import invoke_llm
from backend.config import get_settings

settings = get_settings()

TESTS = [
    {
        "name": "Basic response",
        "system": "You are a helpful assistant. Keep answers under 20 words.",
        "user": "What is 2 + 2?",
    },
    {
        "name": "Shopping domain awareness",
        "system": "You are a shopping assistant. Keep answers under 30 words.",
        "user": "Suggest one feature to look for when buying a budget smartphone.",
    },
    {
        "name": "Hindi language test",
        "system": "You are a multilingual assistant. Reply in Hindi. Keep answers under 20 words.",
        "user": "नमस्ते! आप कैसे हैं?",
    },
]


def run_tests():
    print(f"\n{'='*60}")
    print(f"  Ollama Integration Test")
    print(f"  Model : {settings.ollama_model}")
    print(f"  URL   : {settings.ollama_base_url}")
    print(f"{'='*60}\n")

    passed = 0
    for i, test in enumerate(TESTS, 1):
        print(f"[Test {i}] {test['name']}")
        print(f"  Input : {test['user']}")
        t0 = time.perf_counter()
        try:
            response = invoke_llm(
                system_prompt=test["system"],
                user_message=test["user"],
                temperature=0.3,
            )
            latency = round((time.perf_counter() - t0) * 1000)
            print(f"  Output: {response.strip()[:120]}")
            print(f"  Latency: {latency}ms  ✓ PASSED\n")
            passed += 1
        except Exception as e:
            print(f"  ERROR: {e}  ✗ FAILED\n")

    print(f"{'='*60}")
    print(f"  Results: {passed}/{len(TESTS)} tests passed")
    print(f"{'='*60}\n")
    sys.exit(0 if passed == len(TESTS) else 1)


if __name__ == "__main__":
    run_tests()
